generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ──────────────────────────────────────────────
// AUTH
// ──────────────────────────────────────────────

model User {
  id                  String              @id @default(cuid())
  email               String?             @unique
  phone               String?             @unique
  name                String?
  avatarUrl           String?
  role                Role                @default(GUEST)
  emailNotifications  Boolean             @default(true)
  smsNotifications    Boolean             @default(true)
  notificationChannel NotificationChannel @default(BOTH)
  createdAt           DateTime            @default(now())
  deletionRequestedAt DateTime?
  deletionScheduledAt DateTime?

  events         Event[]
  coHostedEvents EventCoHost[]
  magicTokens    MagicToken[]
  sessions       Session[]
  rsvps          RSVP[]
}

enum Role {
  GUEST
  HOST
  ADMIN
}

enum NotificationChannel {
  EMAIL
  SMS
  BOTH
}

enum MagicTokenType {
  LOGIN
  EMAIL_CHANGE
  PHONE_CHANGE
}

model MagicToken {
  id        String         @id @default(cuid())
  userId    String
  token     String         @unique
  expiresAt DateTime
  createdAt DateTime       @default(now())
  used      Boolean        @default(false)
  type      MagicTokenType @default(LOGIN)
  metadata  String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model SystemConfig {
  key   String @id
  value String
}

model Session {
  id        String   @id @default(cuid())
  userId    String
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model HostInviteCode {
  id        String    @id @default(cuid())
  code      String    @unique
  note      String?
  uses      Int       @default(0)
  maxUses   Int?
  expiresAt DateTime?
  active    Boolean   @default(true)
  createdAt DateTime  @default(now())
}

// ──────────────────────────────────────────────
// EVENTS
// ──────────────────────────────────────────────

model Event {
  id              String       @id @default(cuid())
  slug            String       @unique
  title           String
  description     String?
  startAt         DateTime
  endAt           DateTime?
  timezone        String       @default("America/New_York")
  locationType    LocationType @default(PHYSICAL)
  locationName    String?
  locationAddress String?
  virtualUrl      String?
  capacity        Int?
  visibility      Visibility   @default(UNLISTED)
  hostId          String
  status          EventStatus  @default(DRAFT)

  // RSVP settings
  rsvpDeadline           DateTime?
  allowEditAfterDeadline Boolean      @default(false)
  approvalRequired       Boolean      @default(false)
  plusOneAllowed         Boolean      @default(false)
  plusOneMax             Int          @default(1)
  plusOneNamesRequired   Boolean      @default(false)
  guestListVis           GuestListVis @default(ALL)
  guestSharingEnabled    Boolean      @default(true)
  guestsCanInvite        Boolean      @default(false)

  // Feature flags
  commentsEnabled      Boolean @default(true)
  maybeEnabled         Boolean @default(true)
  questionnaireEnabled Boolean @default(false)
  showTimestamps       Boolean @default(true)
  passwordHash         String?
  hostDisplayName      String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  host              User                   @relation(fields: [hostId], references: [id])
  coHosts           EventCoHost[]
  theme             EventTheme?
  reminderSettings  EventReminderSettings?
  infoSections      EventInfoSection[]
  rsvps             RSVP[]
  invitations       Invitation[]
  updates           EventUpdate[]
  potluckItems      PotluckItem[]
  sentReminders     SentReminder[]
  comments          Comment[]
  rsvpFields        RSVPField[]
  checkIns          CheckIn[]
  activityEvents    ActivityEvent[]
  polls             Poll[]
  coHostInvitations CoHostInvitation[]
}

enum LocationType {
  PHYSICAL
  VIRTUAL
  TBD
}

enum Visibility {
  PUBLIC
  UNLISTED
  PRIVATE
}

enum EventStatus {
  DRAFT
  PUBLISHED
  CANCELLED
  DELETED
}

enum GuestListVis {
  ALL
  GUESTS_ONLY
  HOST_ONLY
}

model EventCoHost {
  id          String  @id @default(cuid())
  eventId     String
  userId      String
  displayName String?

  event Event @relation(fields: [eventId], references: [id], onDelete: Cascade)
  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([eventId, userId])
}

model EventTheme {
  id              String    @id @default(cuid())
  eventId         String    @unique
  baseTheme       BaseTheme @default(DARK)
  gradientFrom    String    @default("#7c3aed")
  gradientTo      String    @default("#1e40af")
  accentColor     String    @default("#a855f7")
  coverImageUrl   String?
  appliedPresetId String?
  cardOpacity     Float?
  fontId          String? // heading font id from lib/fonts.ts; null = base default
  effectId        String? // animated background set from lib/effects.ts; null = none
  effectDensity   String? // sparse | medium | dense
  effectSpeed     String? // gentle | medium | lively

  event Event @relation(fields: [eventId], references: [id], onDelete: Cascade)
}

enum BaseTheme {
  DARK
  SOFT
  BOLD
}

model ThemePreset {
  id               String    @id @default(cuid())
  name             String
  emoji            String    @default("🎨")
  base             BaseTheme
  gradientFrom     String
  gradientTo       String
  accentColor      String
  seasonal         Boolean   @default(false)
  active           Boolean   @default(true)
  sortOrder        Int       @default(0)
  month            Int?
  cardOpacity      Float?
  fontId           String? // heading font id from lib/fonts.ts; null = base default
  createdAt        DateTime  @default(now())
  originalSnapshot Json?
  defaultSnapshot  Json?
}

// Partiful-style info chips: Dress Code, Food, Parking, Link, Custom
model EventInfoSection {
  id      String  @id @default(cuid())
  eventId String
  type    String // icon key: "shirt", "utensils", "parking", "link", "info", "music", "gift", "bed", "mappin", "calendar", "sparkles", "filetext", "camera", "phone"
  title   String? // deprecated — kept for backward compatibility
  content String
  url     String?
  order   Int     @default(0)

  event Event @relation(fields: [eventId], references: [id], onDelete: Cascade)
}

model EventReminderSettings {
  id               String  @id @default(cuid())
  eventId          String  @unique
  emailWeekBefore  Boolean @default(false)
  emailDayBefore   Boolean @default(true)
  emailHoursBefore Int     @default(0) // 0 = disabled
  smsWeekBefore    Boolean @default(false)
  smsDayBefore     Boolean @default(false)
  smsHoursBefore   Int     @default(0)
  nudgeUnresponded Boolean @default(true)

  event Event @relation(fields: [eventId], references: [id], onDelete: Cascade)
}

// ──────────────────────────────────────────────
// RSVP
// ──────────────────────────────────────────────

model RSVPField {
  id        String        @id @default(cuid())
  eventId   String
  label     String
  fieldType RSVPFieldType
  required  Boolean       @default(false)
  options   String? // JSON array of strings for SELECT/CHECKBOX types
  order     Int           @default(0)

  event   Event        @relation(fields: [eventId], references: [id], onDelete: Cascade)
  answers RSVPAnswer[]
}

enum RSVPFieldType {
  TEXT
  SELECT
  CHECKBOX
  TEXTAREA
}

model RSVP {
  id           String     @id @default(cuid())
  eventId      String
  guestName    String
  guestEmail   String?
  guestPhone   String?
  status       RSVPStatus
  plusOneCount Int        @default(0)
  // SEC-28: unguessable random token (v4 UUID, CSPRNG-backed). editToken is the
  // sole guest edit credential AND a PRIVATE-event gate bypass, and it travels in
  // URLs / SMS / Referer — so it must not be a cuid(), whose embedded timestamp +
  // monotonic counter make it partially predictable rather than a secret. This is
  // a Prisma client-side default (not a DB DEFAULT), so no migration is required;
  // existing rows keep their tokens, every new RSVP gets a random UUID.
  editToken    String     @unique @default(uuid(4))
  approved     Boolean    @default(true) // false when approvalRequired is on
  responded    Boolean    @default(true)
  note         String?
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
  userId       String?

  event         Event          @relation(fields: [eventId], references: [id], onDelete: Cascade)
  user          User?          @relation(fields: [userId], references: [id], onDelete: SetNull)
  answers       RSVPAnswer[]
  checkIn       CheckIn?
  plusOneGuests PlusOneGuest[]
}

model PlusOneGuest {
  id     String @id @default(cuid())
  rsvpId String
  name   String
  order  Int    @default(0)

  rsvp RSVP @relation(fields: [rsvpId], references: [id], onDelete: Cascade)

  @@index([rsvpId])
}

enum RSVPStatus {
  GOING
  MAYBE
  NO
  INVITED
}

model RSVPAnswer {
  id          String @id @default(cuid())
  rsvpId      String
  rsvpFieldId String
  value       String

  rsvp      RSVP      @relation(fields: [rsvpId], references: [id], onDelete: Cascade)
  rsvpField RSVPField @relation(fields: [rsvpFieldId], references: [id], onDelete: Cascade)

  @@unique([rsvpId, rsvpFieldId])
}

// ──────────────────────────────────────────────
// INVITATIONS & COMMUNICATION
// ──────────────────────────────────────────────

model Invitation {
  id      String        @id @default(cuid())
  eventId String
  sentTo  String // email or phone number
  channel InviteChannel
  sentAt  DateTime      @default(now())
  rsvpId  String?

  event Event @relation(fields: [eventId], references: [id], onDelete: Cascade)
}

enum InviteChannel {
  EMAIL
  SMS
}

model EventUpdate {
  id           String   @id @default(cuid())
  eventId      String
  body         String
  notifyGuests Boolean  @default(true)
  createdAt    DateTime @default(now())

  event Event @relation(fields: [eventId], references: [id], onDelete: Cascade)
}

// ──────────────────────────────────────────────
// SOCIAL
// ──────────────────────────────────────────────

model Comment {
  id        String   @id @default(cuid())
  eventId   String
  guestName String
  rsvpId    String?
  body      String
  parentId  String?
  createdAt DateTime @default(now())

  event   Event     @relation(fields: [eventId], references: [id], onDelete: Cascade)
  parent  Comment?  @relation("CommentReplies", fields: [parentId], references: [id])
  replies Comment[] @relation("CommentReplies")
}

// ──────────────────────────────────────────────
// POTLUCK
// ──────────────────────────────────────────────

model PotluckItem {
  id        String   @id @default(cuid())
  eventId   String
  label     String
  quantity  Int      @default(1)
  createdAt DateTime @default(now())

  event  Event          @relation(fields: [eventId], references: [id], onDelete: Cascade)
  claims PotluckClaim[]
}

model PotluckClaim {
  id            String   @id @default(cuid())
  potluckItemId String
  guestName     String
  quantity      Int      @default(1)
  createdAt     DateTime @default(now())

  potluckItem PotluckItem @relation(fields: [potluckItemId], references: [id], onDelete: Cascade)

  @@index([potluckItemId])
}

// ──────────────────────────────────────────────
// REMINDERS
// ──────────────────────────────────────────────

model SentReminder {
  id      String   @id @default(cuid())
  eventId String
  type    String // email_week | email_day | email_hours | sms_week | sms_day | sms_hours | nudge_email
  sentAt  DateTime @default(now())

  event Event @relation(fields: [eventId], references: [id], onDelete: Cascade)

  @@unique([eventId, type])
}

// ──────────────────────────────────────────────
// CHECK-IN
// ──────────────────────────────────────────────

model CheckIn {
  id          String   @id @default(cuid())
  eventId     String
  rsvpId      String   @unique
  checkedInAt DateTime @default(now())
  checkedInBy String?

  event Event @relation(fields: [eventId], references: [id], onDelete: Cascade)
  rsvp  RSVP  @relation(fields: [rsvpId], references: [id], onDelete: Cascade)
}

// ──────────────────────────────────────────────
// ACTIVITY LOG
// ──────────────────────────────────────────────

model ActivityEvent {
  id        String   @id @default(cuid())
  eventId   String
  type      String // rsvp_new | rsvp_update | event_title | event_description | event_date | event_location | info_add | info_edit | info_delete
  actorName String?
  detail    String
  createdAt DateTime @default(now())

  event Event @relation(fields: [eventId], references: [id], onDelete: Cascade)
}

// ──────────────────────────────────────────────
// POLLS
// ──────────────────────────────────────────────

model Poll {
  id               String   @id @default(cuid())
  eventId          String
  question         String
  multiChoice      Boolean  @default(false)
  allowGuestsToAdd Boolean  @default(false)
  locked           Boolean  @default(false)
  hideVoters       Boolean  @default(false)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  event   Event        @relation(fields: [eventId], references: [id], onDelete: Cascade)
  options PollOption[]
  votes   PollVote[]
}

model PollOption {
  id          String   @id @default(cuid())
  pollId      String
  text        String
  creatorName String? // Null if created by host, guestName if write-in
  createdAt   DateTime @default(now())

  poll  Poll       @relation(fields: [pollId], references: [id], onDelete: Cascade)
  votes PollVote[]
}

model PollVote {
  id           String   @id @default(cuid())
  pollId       String
  pollOptionId String
  voterName    String // Name of the guest or host voting
  userId       String? // Link to User if they are logged in
  createdAt    DateTime @default(now())

  poll   Poll       @relation(fields: [pollId], references: [id], onDelete: Cascade)
  option PollOption @relation(fields: [pollOptionId], references: [id], onDelete: Cascade)

  @@unique([pollOptionId, voterName])
}

// ──────────────────────────────────────────────
// RATE LIMITING & LOCKS
// ──────────────────────────────────────────────

model RateLimit {
  key      String   @id
  points   Int
  expireAt DateTime
}

model CronLock {
  jobName  String   @id
  lockedAt DateTime
  expireAt DateTime
}

model CoHostInvitation {
  id        String   @id @default(cuid())
  eventId   String
  email     String
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())

  event Event @relation(fields: [eventId], references: [id], onDelete: Cascade)

  @@unique([eventId, email])
}
