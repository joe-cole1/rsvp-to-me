generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "sqlite"
}

// ──────────────────────────────────────────────
// AUTH
// ──────────────────────────────────────────────

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String?
  avatarUrl String?
  role      Role     @default(HOST)
  createdAt DateTime @default(now())

  events         Event[]
  coHostedEvents EventCoHost[]
  magicTokens    MagicToken[]
  sessions       Session[]
  rsvps          RSVP[]
}

enum Role {
  HOST
  ADMIN
}

model MagicToken {
  id        String   @id @default(cuid())
  userId    String
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())
  used      Boolean  @default(false)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Session {
  id        String   @id @default(cuid())
  userId    String
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model HostInviteCode {
  id        String    @id @default(cuid())
  code      String    @unique
  note      String?
  uses      Int       @default(0)
  maxUses   Int?
  expiresAt DateTime?
  active    Boolean   @default(true)
  createdAt DateTime  @default(now())
}

// ──────────────────────────────────────────────
// EVENTS
// ──────────────────────────────────────────────

model Event {
  id              String       @id @default(cuid())
  slug            String       @unique
  title           String
  description     String?
  startAt         DateTime
  endAt           DateTime?
  timezone        String       @default("America/New_York")
  locationType    LocationType @default(PHYSICAL)
  locationName    String?
  locationAddress String?
  virtualUrl      String?
  capacity        Int?
  visibility      Visibility   @default(UNLISTED)
  hostId          String
  status          EventStatus  @default(DRAFT)

  // RSVP settings
  rsvpDeadline      DateTime?
  approvalRequired  Boolean    @default(false)
  plusOneAllowed    Boolean    @default(true)
  plusOneMax        Int        @default(1)
  guestListVis      GuestListVis @default(ALL)

  // Feature flags
  commentsEnabled      Boolean    @default(true)
  maybeEnabled         Boolean    @default(true)
  questionnaireEnabled Boolean    @default(false)
  showTimestamps       Boolean    @default(true)
  password             String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  host            User              @relation(fields: [hostId], references: [id])
  coHosts         EventCoHost[]
  theme           EventTheme?
  reminderSettings EventReminderSettings?
  infoSections    EventInfoSection[]
  rsvps           RSVP[]
  invitations     Invitation[]
  updates         EventUpdate[]
  potluckItems    PotluckItem[]
  sentReminders   SentReminder[]
  comments        Comment[]
  rsvpFields      RSVPField[]
  checkIns        CheckIn[]
}

enum LocationType {
  PHYSICAL
  VIRTUAL
  TBD
}

enum Visibility {
  PUBLIC
  UNLISTED
  PRIVATE
}

enum EventStatus {
  DRAFT
  PUBLISHED
  CANCELLED
}

enum GuestListVis {
  ALL
  GUESTS_ONLY
  HOST_ONLY
}

model EventCoHost {
  id      String @id @default(cuid())
  eventId String
  userId  String

  event Event @relation(fields: [eventId], references: [id], onDelete: Cascade)
  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([eventId, userId])
}

model EventTheme {
  id            String    @id @default(cuid())
  eventId       String    @unique
  baseTheme     BaseTheme @default(DARK)
  accentColor   String    @default("#a855f7")
  coverImageUrl String?

  event Event @relation(fields: [eventId], references: [id], onDelete: Cascade)
}

enum BaseTheme {
  DARK
  SOFT
  BOLD
}

// Partiful-style info chips: Dress Code, Food, Parking, Link, Custom
model EventInfoSection {
  id      String          @id @default(cuid())
  eventId String
  type    InfoSectionType
  title   String?         // Used for CUSTOM type, or overrides default label
  content String          // Main text content
  url     String?         // Used for LINK type
  order   Int             @default(0)

  event Event @relation(fields: [eventId], references: [id], onDelete: Cascade)
}

enum InfoSectionType {
  DRESS_CODE
  FOOD
  PARKING
  LINK
  CUSTOM
}

model EventReminderSettings {
  id               String  @id @default(cuid())
  eventId          String  @unique
  emailWeekBefore  Boolean @default(false)
  emailDayBefore   Boolean @default(true)
  emailHoursBefore Int     @default(2)   // 0 = disabled
  smsWeekBefore    Boolean @default(false)
  smsDayBefore     Boolean @default(false)
  smsHoursBefore   Int     @default(0)
  nudgeUnresponded Boolean @default(true)
  postEventPrompt  Boolean @default(false)

  event Event @relation(fields: [eventId], references: [id], onDelete: Cascade)
}

// ──────────────────────────────────────────────
// RSVP
// ──────────────────────────────────────────────

model RSVPField {
  id        String        @id @default(cuid())
  eventId   String
  label     String
  fieldType RSVPFieldType
  required  Boolean       @default(false)
  options   String?       // JSON array of strings for SELECT/CHECKBOX types
  order     Int           @default(0)

  event   Event        @relation(fields: [eventId], references: [id], onDelete: Cascade)
  answers RSVPAnswer[]
}

enum RSVPFieldType {
  TEXT
  SELECT
  CHECKBOX
  TEXTAREA
}

model RSVP {
  id           String     @id @default(cuid())
  eventId      String
  guestName    String
  guestEmail   String?
  guestPhone   String?
  status       RSVPStatus
  plusOneCount Int        @default(0)
  editToken    String     @unique @default(cuid())
  approved     Boolean    @default(true) // false when approvalRequired is on
  note         String?
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
  userId       String?

  event   Event        @relation(fields: [eventId], references: [id], onDelete: Cascade)
  user    User?        @relation(fields: [userId], references: [id], onDelete: SetNull)
  answers RSVPAnswer[]
  checkIn CheckIn?
}

enum RSVPStatus {
  GOING
  MAYBE
  NO
}

model RSVPAnswer {
  id          String @id @default(cuid())
  rsvpId      String
  rsvpFieldId String
  value       String

  rsvp      RSVP      @relation(fields: [rsvpId], references: [id], onDelete: Cascade)
  rsvpField RSVPField @relation(fields: [rsvpFieldId], references: [id], onDelete: Cascade)

  @@unique([rsvpId, rsvpFieldId])
}

// ──────────────────────────────────────────────
// INVITATIONS & COMMUNICATION
// ──────────────────────────────────────────────

model Invitation {
  id      String        @id @default(cuid())
  eventId String
  sentTo  String        // email or phone number
  channel InviteChannel
  sentAt  DateTime      @default(now())
  rsvpId  String?

  event Event @relation(fields: [eventId], references: [id], onDelete: Cascade)
}

enum InviteChannel {
  EMAIL
  SMS
}

model EventUpdate {
  id           String   @id @default(cuid())
  eventId      String
  body         String
  notifyGuests Boolean  @default(true)
  createdAt    DateTime @default(now())

  event Event @relation(fields: [eventId], references: [id], onDelete: Cascade)
}

// ──────────────────────────────────────────────
// SOCIAL
// ──────────────────────────────────────────────

model Comment {
  id        String   @id @default(cuid())
  eventId   String
  guestName String
  rsvpId    String?
  body      String
  parentId  String?
  createdAt DateTime @default(now())

  event   Event     @relation(fields: [eventId], references: [id], onDelete: Cascade)
  parent  Comment?  @relation("CommentReplies", fields: [parentId], references: [id])
  replies Comment[] @relation("CommentReplies")
}

// ──────────────────────────────────────────────
// POTLUCK
// ──────────────────────────────────────────────

model PotluckItem {
  id        String    @id @default(cuid())
  eventId   String
  label     String
  claimedBy String?
  claimedAt DateTime?
  createdAt DateTime  @default(now())

  event Event @relation(fields: [eventId], references: [id], onDelete: Cascade)
}

// ──────────────────────────────────────────────
// REMINDERS
// ──────────────────────────────────────────────

model SentReminder {
  id      String   @id @default(cuid())
  eventId String
  type    String   // email_week | email_day | email_hours | sms_week | sms_day | sms_hours | nudge_email
  sentAt  DateTime @default(now())

  event Event @relation(fields: [eventId], references: [id], onDelete: Cascade)

  @@unique([eventId, type])
}

// ──────────────────────────────────────────────
// CHECK-IN
// ──────────────────────────────────────────────

model CheckIn {
  id          String   @id @default(cuid())
  eventId     String
  rsvpId      String   @unique
  checkedInAt DateTime @default(now())
  checkedInBy String?

  event Event @relation(fields: [eventId], references: [id], onDelete: Cascade)
  rsvp  RSVP  @relation(fields: [rsvpId], references: [id], onDelete: Cascade)
}
