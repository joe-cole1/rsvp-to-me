{
  "name": "rsvp-to-me",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": ">=22.23.1 <23",
    "npm": ">=10.9.0 <11"
  },
  "scripts": {
    "dev": "next dev",
    "dev:sync": "bash scripts/dev-sync.sh",
    "dev:reset": "bash scripts/dev-reset.sh",
    "build": "next build",
    "start": "prisma migrate deploy && next start",
    "lint": "eslint",
    "prepare": "husky",
    "db:migrate": "prisma migrate dev",
    "db:generate": "prisma generate",
    "db:studio": "prisma studio",
    "db:seed": "tsx prisma/seed.ts",
    "db:push": "prisma db push",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:ci": "vitest run --reporter=verbose",
    "test:integration": "vitest run --config vitest.integration.config.ts",
    "test:integration:watch": "vitest --config vitest.integration.config.ts",
    "test:components": "vitest run --config vitest.components.config.ts",
    "test:components:watch": "vitest --config vitest.components.config.ts",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:headed": "playwright test --headed",
    "test:e2e:local": "DATABASE_URL=\"postgresql://postgres:postgres_password_here@127.0.0.1:5432/rsvp_test\" REDIS_URL=\"redis://:redis_password_placeholder@127.0.0.1:6379\" SESSION_SECRET=\"test-secret-that-is-at-least-32-characters-long\" playwright test",
    "test:e2e:local:ui": "DATABASE_URL=\"postgresql://postgres:postgres_password_here@127.0.0.1:5432/rsvp_test\" REDIS_URL=\"redis://:redis_password_placeholder@127.0.0.1:6379\" SESSION_SECRET=\"test-secret-that-is-at-least-32-characters-long\" playwright test --ui",
    "test:e2e:docker": "bash scripts/run-e2e-docker.sh"
  },
  "dependencies": {
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "@radix-ui/themes": "^3.3.0",
    "@types/qrcode": "^1.5.6",
    "bcryptjs": "^3.0.3",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "dotenv": "^17.4.2",
    "highlight.js": "^11.11.1",
    "html-to-text": "^10.0.0",
    "iron-session": "^8.0.4",
    "lucide-react": "^1.24.0",
    "next": "16.2.10",
    "node-cron": "^4.6.0",
    "nodemailer": "^9.0.3",
    "pg": "^8.22.0",
    "prisma": "^7.8.0",
    "qrcode": "^1.5.4",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "react-markdown": "^10.1.0",
    "redis": "^6.1.0",
    "rehype-highlight": "^7.0.2",
    "rehype-slug": "^6.0.0",
    "remark-gfm": "^4.0.1",
    "tailwind-merge": "^3.6.0",
    "twilio": "^6.0.2",
    "zod": "^4.4.3"
  },
  "overrides": {
    "postcss": "^8.5.15",
    "@hono/node-server": "1.19.14",
    "js-yaml": "^4.2.0",
    "esbuild": "0.28.1"
  },
  "lint-staged": {
    "*.{ts,tsx}": "prettier --write"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "@react-email/ui": "^6.6.9",
    "@tailwindcss/postcss": "^4",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/bcryptjs": "^3.0.0",
    "@types/html-to-text": "^9.0.4",
    "@types/node": "^26",
    "@types/nodemailer": "^8.0.1",
    "@types/pg": "^8.20.0",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitest/coverage-v8": "^4.1.10",
    "eslint": "^9",
    "eslint-config-next": "16.2.10",
    "fast-check": "^4.9.0",
    "husky": "^9",
    "jsdom": "^29.1.1",
    "lint-staged": "^17",
    "prettier": "^3.9.6",
    "react-email": "^6.8.1",
    "tailwindcss": "^4",
    "tsx": "^4.23.1",
    "typescript": "^6",
    "vitest": "^4.1.9",
    "wait-on": "^9.0.10"
  }
}
