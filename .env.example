# Database (SQLite — path relative to project root)
DATABASE_URL="file:./prisma/dev.db"

# Session encryption (generate with: openssl rand -base64 32)
SESSION_SECRET=""

# Registration mode
# false (default) — invite code required; set HOST_INVITE_CODE below
# true            — anyone can register; invite code field hidden
OPEN_REGISTRATION="false"

# Host registration invite code (only used when OPEN_REGISTRATION=false)
HOST_INVITE_CODE="letmein"

# Initial admin email (existing users matching this email are automatically upgraded to admin)
INITIAL_ADMIN_EMAIL=""

# Test Seeding (set to "true" to seed rich test data in development when db is empty)
SEED_TEST_DATA="false"


# Email (SMTP — leave blank to log emails to console instead)
SMTP_HOST=""              # e.g. smtp.gmail.com
SMTP_PORT="587"           # 587 = STARTTLS, 465 = SSL
SMTP_SECURE="false"       # set to "true" for port 465
SMTP_USER=""              # SMTP username / email address
SMTP_PASS=""              # SMTP password or app password
EMAIL_FROM="RSVP to Me <noreply@yourdomain.com>"

# App URL (no trailing slash)
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# SMS / text blast (Twilio — optional)
TWILIO_ACCOUNT_SID=""
TWILIO_AUTH_TOKEN=""
TWILIO_PHONE_NUMBER=""

# Cloudflare Worker email transport (optional fallback, prioritizes database settings)
CLOUDFLARE_WORKER_EMAIL_URL=""
CLOUDFLARE_WORKER_API_SECRET=""
