# ── Docker Compose deployments (the usual setup) ──────────────────────────────
# docker-compose.yml uses these passwords to run the bundled PostgreSQL and Redis
# containers AND to build the connection URLs the app uses. Set strong values here.
# REQUIRED: there are no compose defaults — docker compose refuses to start if
# either is unset or empty.
POSTGRES_PASSWORD="change-me-postgres"
REDIS_PASSWORD="change-me-redis"

# ── Running WITHOUT Docker Compose (advanced / local dev) ─────────────────────
# If you run the app against your own database/cache (not the bundled containers),
# set these instead. When using docker-compose.yml these are ignored — the values
# above are used to construct the URLs.
# DATABASE_URL="postgresql://postgres:password@localhost:5432/rsvp_db"   # PostgreSQL 18 required
# REDIS_URL="redis://:password@localhost:6379"

# Session encryption (generate with: openssl rand -base64 32)
SESSION_SECRET=""

# At-rest encryption key for stored credentials (SMTP/Twilio/Cloudflare secrets).
# Generate with: openssl rand -base64 32. Falls back to SESSION_SECRET if left blank.
ENCRYPTION_KEY=""

# Log verbosity: trace | debug | info | warn | error | fatal (default: info)
LOG_LEVEL=""

# Optional trusted header for client IP extraction behind reverse proxies (e.g., CF-Connecting-IP, X-Real-IP)
TRUSTED_IP_HEADER=""

# Registration mode
# false (default) — invite code required; set HOST_INVITE_CODE below
# true            — anyone can register; invite code field hidden
OPEN_REGISTRATION="false"

# Host registration invite code (only used when OPEN_REGISTRATION=false).
# REQUIRED in production: this placeholder (and any code under 10 chars) is
# rejected at startup — generate a strong value, e.g. openssl rand -hex 8
HOST_INVITE_CODE="CHANGE_THIS_TO_A_STRONG_RANDOM_CODE"

# Initial admin email (existing users matching this email are automatically upgraded to admin)
INITIAL_ADMIN_EMAIL=""

# Test Seeding (set to "true" to seed rich test data in development when db is empty)
SEED_TEST_DATA="false"


# Email (SMTP — leave blank to log emails to console instead)
SMTP_HOST=""              # e.g. smtp.gmail.com
SMTP_PORT="587"           # 587 = STARTTLS, 465 = SSL
SMTP_SECURE="false"       # set to "true" for port 465
SMTP_USER=""              # SMTP username / email address
SMTP_PASS=""              # SMTP password or app password
EMAIL_FROM="RSVP to Me <noreply@yourdomain.com>"

# App URL (no trailing slash)
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# SMS / text blast (Twilio — optional)
TWILIO_ACCOUNT_SID=""
TWILIO_AUTH_TOKEN=""
TWILIO_PHONE_NUMBER=""

# Cloudflare Worker email transport (optional fallback, prioritizes database settings)
CLOUDFLARE_WORKER_EMAIL_URL=""
CLOUDFLARE_WORKER_API_SECRET=""

# Cloudflare Email REST API (optional alternative to the Worker; outbound only)
CLOUDFLARE_ACCOUNT_ID=""
CLOUDFLARE_API_TOKEN=""

# Address that inbound guest email replies are forwarded to (Cloudflare Worker inbound routing)
INBOUND_FORWARD_TO=""

# Automated database backups (optional — usually configured from the Admin Panel)
# BACKUP_SCHEDULE: 5-field cron expression, or "disabled" (default: disabled)
BACKUP_SCHEDULE=""
# BACKUP_KEEP_COUNT: how many backup files to retain before rotating out the oldest
BACKUP_KEEP_COUNT=""
